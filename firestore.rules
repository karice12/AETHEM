rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isActiveOperator(userId) {
      // Note: Use get() cautiously for cost, but here it's vital for security
      let user = get(/databases/$(database)/documents/users/$(userId)).data;
      return user.subscriptionStatus == 'active' && user.expiresAt > request.time;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'plan', 'createdAt'])
        && data.uid == request.auth.uid 
        && data.email is string
        && data.plan in ['free', 'monthly', 'yearly']
        && data.createdAt is timestamp
        && (data.get('subscriptionStatus', null) == null || data.get('subscriptionStatus', null) in ['active', 'expired', 'inactive'])
        && (data.get('expiresAt', null) == null || data.get('expiresAt', null) is timestamp)
        && (data.get('termsAccepted', null) == null || data.get('termsAccepted', null) is bool)
        && (data.get('termsAcceptedAt', null) == null || data.get('termsAcceptedAt', null) is timestamp);
    }

    function isValidPrompt(data) {
      return data.keys().hasAll(['userId', 'idea', 'category', 'destination', 'answers', 'result', 'createdAt'])
        && data.userId == request.auth.uid
        && data.idea is string && data.idea.size() <= 2000
        && data.category is string
        && data.destination is string
        && data.result is string && data.result.size() <= 8000
        && data.createdAt is timestamp;
    }

    // --- Routes ---

    // User Profile
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().plan == 'free'
        && incoming().createdAt == request.time;
      
      allow update: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().createdAt == existing().createdAt
        && (
          // Ação: Aceite de Termos LGPD
          (incoming().diff(existing()).affectedKeys().hasOnly(['termsAccepted', 'termsAcceptedAt'])) ||
          // Ação: Update Perfil Básico
          (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email'])) ||
          // Ação: Upgrade de Plano (Backend via Admin costuma ignorar regras, mas aqui deixamos seguro)
          (incoming().diff(existing()).affectedKeys().hasOnly(['plan', 'subscriptionStatus', 'expiresAt', 'updatedAt']))
        );
    }

    // Prompts History
    match /users/{userId}/prompts/{promptId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId)
        && isActiveOperator(userId)
        && isValidId(promptId)
        && isValidPrompt(incoming())
        && incoming().createdAt == request.time;
      
      // Prompts are immutable once forged for integrity
      allow update: if false; 
      allow delete: if isOwner(userId);
    }
  }
}
